# =============================================================================
#  PersonalJobSeeker — Environment Variables
#  Copy to .env and fill in your values. Never commit .env to git.
# =============================================================================

# === Application ===
APP_ENV=development
APP_SECRET_KEY=change-this-to-a-random-64-char-secret-min-32-chars-required
APP_ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# === Admin Account (seeded automatically on first startup) ===
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-strong-admin-password
ADMIN_NAME=Admin

# === Database (PostgreSQL) ===
POSTGRES_DB=jobseeker
POSTGRES_USER=jobseeker
POSTGRES_PASSWORD=change-this-db-password
DATABASE_URL=postgresql+asyncpg://jobseeker:change-this-db-password@postgres:5432/jobseeker

# === ChromaDB ===
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# === JWT ===
JWT_SECRET_KEY=change-this-to-another-random-64-char-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# =============================================================================
#  LLM Providers — Zero Cost Options (pick one or more as fallbacks)
# =============================================================================

# --- Option 1: Ollama (LOCAL, completely free, best quality) ---
# Runs on your own machine. No API key needed.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Option 2: OpenRouter Free Tier (ONLINE, zero cost) ---
# Sign up at https://openrouter.ai — free models available
OPENROUTER_API_KEY=
OPENROUTER_FREE_MODEL=meta-llama/llama-3.1-8b-instruct:free

# --- Option 3: Groq Free Tier (ONLINE, 14,400 req/day free) ---
# Sign up at https://console.groq.com
GROQ_API_KEY=
GROQ_FREE_MODEL=llama-3.1-8b-instant

# --- Option 4: Google Gemini Free Tier (ONLINE, 1M tokens/day free) ---
# Sign up at https://aistudio.google.com
GEMINI_API_KEY=
GEMINI_FREE_MODEL=gemini-1.5-flash

# --- Option 5: OpenAI (PAID — future upgrade path) ---
OPENAI_API_KEY=

# =============================================================================
#  Email Notifications (Gmail SMTP — free with App Password)
#  Setup: https://myaccount.google.com/apppasswords
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM_NAME=JobSeeker Alert
NOTIFICATION_EMAIL=your-email@gmail.com

# === Job Search Settings ===
JOB_SEARCH_INTERVAL_MINUTES=15
DEFAULT_MATCH_THRESHOLD=65
MAX_JOBS_PER_SEARCH=50

# === File Storage ===
UPLOAD_DIR=/app/uploads
GENERATED_DIR=/app/generated
MAX_UPLOAD_SIZE_MB=10

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/ws
